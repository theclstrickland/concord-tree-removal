---
import Base from './Base.astro';
import { site } from '../data/site';

interface Props {
  name: string;
  slug: string;
  county: string;
  desc: string;
}

const { name, slug, county, desc } = Astro.props;
const otherLocations = site.locations.filter(l => l.slug !== slug);
---

<Base
  title={`Tree Service in ${name}, ${site.state} | ${site.name}`}
  description={`Professional tree removal, trimming, and stump grinding in ${name}, ${site.state}. ${desc} Call ${site.phone}.`}
>
  <section class="loc-hero">
    <div class="container">
      <p class="section-label">{county} County, {site.state}</p>
      <h1>Tree Service in {name}, {site.state}</h1>
      <p class="loc-intro">{desc}</p>
      <div class="loc-actions">
        <a href={`tel:${site.phoneTel}`} class="btn btn-cta">Call {site.phone}</a>
        <a href="/contact/" class="btn btn-secondary">Get Free Estimate</a>
      </div>
      <div class="loc-trust">
        {site.trust.map(t => (
          <span>✓ {t}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="loc-services">
    <div class="container">
      <h2>Services in {name}</h2>
      <div class="loc-services-grid">
        {site.services.map(s => (
          <a href={`/${s.slug}/`} class="loc-svc-card">
            <span class="loc-svc-icon" set:html={s.icon} />
            <div>
              <h3>{s.name}</h3>
              <p>{s.shortDesc}</p>
              <span class="loc-svc-price">{s.priceRange}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="loc-nearby">
    <div class="container">
      <h2>Also Serving Nearby Areas</h2>
      <div class="nearby-grid">
        {otherLocations.map(l => (
          <a href={`/${l.slug}/`} class="nearby-tag">{l.name}, {site.state}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="loc-cta">
    <div class="container" style="text-align:center;">
      <h2>Need Tree Service in {name}?</h2>
      <p>Call now for a free estimate. Same-day response available.</p>
      <a href={`tel:${site.phoneTel}`} class="btn btn-cta">Call {site.phone}</a>
    </div>
  </section>
</Base>

<style>
  .loc-hero {
    background: linear-gradient(135deg, var(--green-900), var(--green-800));
    background-image: url('/images/hero-location.svg');
    background-size: cover;
    background-position: center;
    color: var(--white);
    padding: 72px 0 80px;
  }
  .loc-hero h1 { color: var(--white); margin-bottom: 16px; }
  .loc-intro { font-size: 18px; color: rgba(255,255,255,0.8); max-width: 600px; margin-bottom: 28px; }
  .loc-actions { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 28px; }
  .loc-hero .btn-secondary { border-color: rgba(255,255,255,0.3); color: var(--white); }
  .loc-trust { display: flex; flex-wrap: wrap; gap: 16px; font-size: 14px; color: var(--green-400); font-weight: 500; }

  .loc-services { padding: 64px 0; }
  .loc-services h2 { text-align: center; margin-bottom: 32px; }
  .loc-services-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 800px; margin: 0 auto; }
  .loc-svc-card {
    display: flex;
    gap: 16px;
    padding: 24px;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    transition: all 0.2s;
  }
  .loc-svc-card:hover { border-color: var(--green-400); box-shadow: var(--shadow-md); }
  .loc-svc-icon { flex-shrink: 0; color: var(--green-600); }
  .loc-svc-card h3 { font-size: 17px; margin-bottom: 4px; }
  .loc-svc-card p { font-size: 13px; color: var(--gray-600); margin-bottom: 6px; }
  .loc-svc-price { font-size: 14px; font-weight: 700; color: var(--green-700); }

  .loc-nearby { background: var(--green-50); padding: 48px 0; }
  .loc-nearby h2 { text-align: center; margin-bottom: 24px; }
  .nearby-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; }
  .nearby-tag {
    padding: 10px 20px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.15s;
  }
  .nearby-tag:hover { background: var(--green-600); color: var(--white); }

  .loc-cta { background: var(--green-900); padding: 64px 0; }
  .loc-cta h2 { color: var(--white); margin-bottom: 12px; }
  .loc-cta p { color: rgba(255,255,255,0.7); font-size: 17px; margin-bottom: 24px; }

  @media (max-width: 600px) {
    .loc-services-grid { grid-template-columns: 1fr; }
  }
</style>
