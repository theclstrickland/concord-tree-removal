---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';
import { blogPosts } from '../../data/blog';
---

<Base title={`Tree Care Blog | ${site.name}`} description={`Tree care tips, pricing guides, and expert advice for homeowners in ${site.city}, ${site.state}. From the team at ${site.name}.`}>
  <section class="blog-hero">
    <div class="container">
      <p class="section-label">Our Blog</p>
      <h1>Tree Care Tips for {site.city} Homeowners</h1>
      <p class="blog-hero-sub">Expert advice on tree removal, trimming, pricing, and more from the {site.name} crew.</p>
    </div>
  </section>

  <section class="blog-list">
    <div class="container">
      <div class="blog-grid">
        {blogPosts.map(post => {
          const formattedDate = new Date(post.date + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
          return (
            <a href={`/blog/${post.slug}/`} class="blog-card">
              <div class="blog-card-meta">
                <time datetime={post.date}>{formattedDate}</time>
                <span>{post.readTime}</span>
              </div>
              <h2>{post.title}</h2>
              <p>{post.description}</p>
              <span class="blog-card-link">Read Article</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Base>

<style>
  .blog-hero {
    background: linear-gradient(135deg, var(--green-900), var(--green-800));
    background-image: url('/images/hero-service.svg');
    background-size: cover;
    color: var(--white);
    text-align: center;
    padding: 56px 0 64px;
  }
  .section-label {
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--green-400);
    margin-bottom: 8px;
  }
  .blog-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-bottom: 12px;
    color: var(--white);
  }
  .blog-hero-sub {
    opacity: 0.85;
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .blog-list { padding: 56px 0 80px; }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .blog-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .blog-card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--gray-500);
    margin-bottom: 12px;
  }
  .blog-card h2 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--green-900);
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .blog-card p {
    font-size: 14px;
    color: var(--gray-600);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }
  .blog-card-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--green-600);
  }
  @media (max-width: 768px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
