---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
---

<Base title={`${site.name} | ${site.tagline} in ${site.city}, ${site.state}`}>

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="hero-badge">Serving {site.county} County & Surrounding Areas</span>
        <h1>Professional Tree Removal in {site.city}, {site.state}</h1>
        <p class="hero-sub">
          From hazardous tree removal to expert trimming and stump grinding — we keep your property safe, clean, and looking its best. Free estimates. No hidden fees.
        </p>
        <div class="hero-actions">
          <a href={`tel:${site.phoneTel}`} class="btn btn-cta">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            Call {site.phone}
          </a>
          <a href="/contact/" class="btn btn-secondary">Get Free Estimate</a>
        </div>
        <div class="hero-trust">
          {site.trust.slice(0, 4).map(t => (
            <span class="trust-badge">✓ {t}</span>
          ))}
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card">
          <div class="hero-card-icon">🌲</div>
          <div class="hero-card-title">Tree Experts</div>
          <div class="hero-card-stat">Cabarrus County's Trusted Tree Service</div>
          <div class="hero-card-divider"></div>
          <div class="hero-card-items">
            <div class="hero-card-item"><span>✓</span> Licensed & Insured</div>
            <div class="hero-card-item"><span>✓</span> Free Estimates</div>
            <div class="hero-card-item"><span>✓</span> 24/7 Emergency</div>
            <div class="hero-card-item"><span>✓</span> Same-Day Service</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Services ── -->
  <section class="services" id="services">
    <div class="container">
      <p class="section-label">Our Services</p>
      <h2 class="section-title">Complete Tree Care Solutions</h2>
      <p class="section-subtitle">Whether you need a single tree removed or an entire lot cleared, our experienced crew has the equipment and expertise to handle it safely.</p>

      <div class="services-grid">
        {site.services.map(s => (
          <a href={`/${s.slug}/`} class="service-card">
            <span class="service-icon">{s.icon}</span>
            <h3>{s.name}</h3>
            <p>{s.shortDesc}</p>
            <span class="service-price">{s.priceRange}</span>
            <span class="service-link">Learn More →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Why Us ── -->
  <section class="why-us">
    <div class="container">
      <p class="section-label">Why Choose Us</p>
      <h2 class="section-title">The {site.city} Tree Service Difference</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">⚡</div>
          <h3>Fast Response</h3>
          <p>Same-day estimates and rapid scheduling. When storms hit, we're there within hours — not days.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🛡️</div>
          <h3>Fully Insured</h3>
          <p>Complete liability coverage and workers' comp on every job. Your property is always protected.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">💰</div>
          <h3>Honest Pricing</h3>
          <p>Free estimates with flat-rate quotes. The price we quote is the price you pay — no hidden fees or surprise charges.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🏆</div>
          <h3>Expert Crew</h3>
          <p>Trained professionals with the equipment to handle any job — from tight residential spaces to large-scale commercial clearing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pricing ── -->
  <section class="pricing" id="pricing">
    <div class="container">
      <p class="section-label">Transparent Pricing</p>
      <h2 class="section-title">Tree Service Costs in {site.city}</h2>
      <p class="section-subtitle">Every property is different. These are typical ranges — your free estimate will include an exact quote for your specific job.</p>

      <div class="pricing-table">
        <div class="pricing-header">
          <span>Service</span>
          <span>Typical Cost</span>
        </div>
        {site.pricing.map(p => (
          <div class="pricing-row">
            <span>{p.service}</span>
            <span class="price-value">{p.price}</span>
          </div>
        ))}
      </div>
      <div class="pricing-cta">
        <p>Need an exact quote? Call us for a free, no-obligation estimate.</p>
        <a href={`tel:${site.phoneTel}`} class="btn btn-primary">Call {site.phone}</a>
      </div>
    </div>
  </section>

  <!-- ── Locations ── -->
  <section class="locations" id="locations">
    <div class="container">
      <p class="section-label">Service Areas</p>
      <h2 class="section-title">Serving {site.city} & Surrounding Communities</h2>
      <div class="locations-grid">
        {site.locations.map(l => (
          <a href={`/${l.slug}/`} class="location-card">
            <h3>{l.name}, {site.state}</h3>
            <p class="loc-pop">Population: {l.pop}</p>
            <span class="location-link">View Services →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="faq" id="faq">
    <div class="container">
      <p class="section-label">Common Questions</p>
      <h2 class="section-title">Tree Removal FAQ</h2>
      <div class="faq-list">
        {site.faqs.map(f => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Final CTA ── -->
  <section class="final-cta">
    <div class="container final-cta-inner">
      <h2>Ready to Get Started?</h2>
      <p>Call now for a free estimate or fill out our contact form. We'll get back to you within the hour.</p>
      <div class="final-actions">
        <a href={`tel:${site.phoneTel}`} class="btn btn-cta">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call {site.phone}
        </a>
        <a href="/contact/" class="btn btn-secondary">Request Estimate Online</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Hero ── */
  .hero {
    background: linear-gradient(135deg, var(--green-900) 0%, var(--green-800) 50%, var(--green-700) 100%);
    padding: 80px 0 100px;
    color: var(--white);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(67,169,109,0.15) 0%, transparent 70%);
    border-radius: 50%;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 60px;
    align-items: center;
    position: relative;
  }
  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 20px;
  }
  .hero h1 {
    color: var(--white);
    margin-bottom: 20px;
    line-height: 1.1;
  }
  .hero-sub {
    font-size: 18px;
    color: rgba(255,255,255,0.8);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 32px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .hero .btn-secondary {
    border-color: rgba(255,255,255,0.4);
    color: var(--white);
  }
  .hero .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--white);
  }
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .trust-badge {
    font-size: 14px;
    color: var(--green-400);
    font-weight: 500;
  }

  /* Hero visual card */
  .hero-card {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-xl);
    padding: 36px;
    backdrop-filter: blur(10px);
  }
  .hero-card-icon { font-size: 48px; margin-bottom: 16px; }
  .hero-card-title {
    font-family: var(--font-heading);
    font-size: 24px;
    margin-bottom: 8px;
  }
  .hero-card-stat {
    font-size: 14px;
    color: var(--green-400);
    margin-bottom: 20px;
  }
  .hero-card-divider {
    height: 1px;
    background: rgba(255,255,255,0.15);
    margin-bottom: 20px;
  }
  .hero-card-items { display: flex; flex-direction: column; gap: 12px; }
  .hero-card-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: rgba(255,255,255,0.85);
  }
  .hero-card-item span { color: var(--green-400); font-weight: 700; }

  /* ── Services ── */
  .services { background: var(--gray-50); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }
  .service-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    transition: all 0.25s;
    display: flex;
    flex-direction: column;
  }
  .service-card:hover {
    border-color: var(--green-400);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }
  .service-icon { font-size: 36px; margin-bottom: 16px; }
  .service-card h3 {
    font-size: 20px;
    margin-bottom: 10px;
  }
  .service-card p {
    font-size: 15px;
    color: var(--gray-600);
    flex: 1;
  }
  .service-price {
    font-weight: 700;
    color: var(--green-700);
    font-size: 15px;
    margin-top: 12px;
  }
  .service-link {
    color: var(--green-600);
    font-weight: 600;
    font-size: 14px;
    margin-top: 12px;
  }

  /* ── Why Us ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }
  .why-card {
    text-align: center;
    padding: 32px 20px;
  }
  .why-icon { font-size: 40px; margin-bottom: 16px; }
  .why-card h3 { font-size: 19px; margin-bottom: 10px; }
  .why-card p { font-size: 14px; color: var(--gray-600); }

  /* ── Pricing ── */
  .pricing { background: var(--gray-50); }
  .pricing-table {
    max-width: 700px;
    margin: 40px auto 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--gray-200);
    background: var(--white);
  }
  .pricing-header {
    display: flex;
    justify-content: space-between;
    padding: 16px 24px;
    background: var(--green-800);
    color: var(--white);
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .pricing-row {
    display: flex;
    justify-content: space-between;
    padding: 16px 24px;
    border-bottom: 1px solid var(--gray-100);
    font-size: 15px;
  }
  .pricing-row:last-child { border-bottom: none; }
  .price-value { font-weight: 700; color: var(--green-700); }
  .pricing-cta {
    text-align: center;
    margin-top: 32px;
  }
  .pricing-cta p {
    font-size: 16px;
    color: var(--gray-600);
    margin-bottom: 16px;
  }

  /* ── Locations ── */
  .locations-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 40px;
  }
  .location-card {
    background: var(--green-50);
    border: 1px solid var(--green-100);
    border-radius: var(--radius-md);
    padding: 24px;
    transition: all 0.2s;
  }
  .location-card:hover {
    background: var(--white);
    border-color: var(--green-400);
    box-shadow: var(--shadow-md);
  }
  .location-card h3 { font-size: 18px; margin-bottom: 6px; }
  .loc-pop { font-size: 13px; color: var(--gray-500); margin-bottom: 8px; }
  .location-link { font-size: 13px; color: var(--green-600); font-weight: 600; }

  /* ── FAQ ── */
  .faq { background: var(--gray-50); }
  .faq-list {
    max-width: 740px;
    margin: 40px auto 0;
  }
  .faq-item {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    margin-bottom: 12px;
    overflow: hidden;
  }
  .faq-item summary {
    padding: 20px 24px;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .faq-item summary::after {
    content: '+';
    font-size: 22px;
    color: var(--green-600);
    font-weight: 300;
    flex-shrink: 0;
    margin-left: 16px;
  }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item p {
    padding: 0 24px 20px;
    font-size: 15px;
    color: var(--gray-600);
    line-height: 1.7;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--green-900);
    padding: 80px 0;
  }
  .final-cta-inner { text-align: center; }
  .final-cta h2 {
    color: var(--white);
    margin-bottom: 16px;
  }
  .final-cta p {
    color: rgba(255,255,255,0.75);
    font-size: 18px;
    margin-bottom: 32px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .final-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .final-cta .btn-secondary {
    border-color: rgba(255,255,255,0.3);
    color: var(--white);
  }
  .final-cta .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { display: none; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .why-grid { grid-template-columns: 1fr 1fr; }
    .locations-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; }
    .locations-grid { grid-template-columns: 1fr; }
    .hero { padding: 56px 0 72px; }
  }
</style>
