---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';
---

<Base title={`Contact Us | ${site.name}`} description={`Get a free estimate from ${site.name}. Call ${site.phone} or fill out our contact form. Serving ${site.city}, ${site.state} and surrounding areas.`}>
  <section class="contact-hero">
    <div class="container">
      <p class="section-label">Contact Us</p>
      <h1>Get Your Free Estimate</h1>
      <p class="hero-sub">
        Ready to get started? Call us directly or fill out the form below and
        we'll get back to you within 1 business hour.
      </p>
    </div>
  </section>

  <!-- ── Quick-Contact Bar ──────────────────────────── -->
  <section class="quick-contact">
    <div class="container">
      <div class="quick-grid">
        <a href={`tel:${site.phoneTel}`} class="quick-card">
          <span class="quick-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </span>
          <span class="quick-label">Call Us Now</span>
          <span class="quick-value">{site.phone}</span>
        </a>
        <div class="quick-card">
          <span class="quick-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <span class="quick-label">Business Hours</span>
          <span class="quick-value">Mon – Sat: 7 AM – 7 PM</span>
        </div>
        <div class="quick-card">
          <span class="quick-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <span class="quick-label">Service Area</span>
          <span class="quick-value">{site.city}, {site.state} & Surrounding</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Form + Sidebar ─────────────────────────────── -->
  <section class="contact-main">
    <div class="container">
      <div class="contact-grid">
        <!-- Form -->
        <div class="form-wrap">
          <h2>Request a Free Estimate</h2>
          <p>Fill out the form and a member of our team will reach out to schedule your free, no-obligation estimate.</p>
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/contact/thank-you/"
            class="contact-form"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden" aria-hidden="true">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="form-row two-col">
              <div class="field">
                <label for="firstName">First Name <span class="req">*</span></label>
                <input type="text" id="firstName" name="firstName" required />
              </div>
              <div class="field">
                <label for="lastName">Last Name <span class="req">*</span></label>
                <input type="text" id="lastName" name="lastName" required />
              </div>
            </div>

            <div class="form-row two-col">
              <div class="field">
                <label for="phone">Phone <span class="req">*</span></label>
                <input type="tel" id="phone" name="phone" required />
              </div>
              <div class="field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" />
              </div>
            </div>

            <div class="field">
              <label for="address">Property Address</label>
              <input type="text" id="address" name="address" placeholder="Street address, city, zip" />
            </div>

            <div class="field">
              <label for="service">Service Needed <span class="req">*</span></label>
              <select id="service" name="service" required>
                <option value="" disabled selected>Select a service…</option>
                {site.services.map((s) => (
                  <option value={s.slug}>{s.name}</option>
                ))}
                <option value="other">Other / Not Sure</option>
              </select>
            </div>

            <div class="field">
              <label for="message">Tell Us About Your Project</label>
              <textarea id="message" name="message" rows="5" placeholder="How many trees? Approximate size? Any access issues? The more detail, the more accurate your estimate."></textarea>
            </div>

            <div class="field">
              <label for="how">How Did You Find Us?</label>
              <select id="how" name="how">
                <option value="" disabled selected>Select…</option>
                <option value="google">Google Search</option>
                <option value="referral">Referral / Word of Mouth</option>
                <option value="social">Social Media</option>
                <option value="drive-by">Drove Past a Job Site</option>
                <option value="other">Other</option>
              </select>
            </div>

            <button type="submit" class="btn btn-primary">Get My Free Estimate →</button>
          </form>
        </div>

        <!-- Sidebar -->
        <aside class="contact-sidebar">
          <div class="sidebar-card">
            <h3>Why Choose {site.name}?</h3>
            <ul class="check-list">
              <li>✓ 100% Free, No-Obligation Estimates</li>
              <li>✓ Licensed & Fully Insured</li>
              <li>✓ Same-Day / Emergency Response</li>
              <li>✓ Clean, Professional Crews</li>
              <li>✓ Competitive, Transparent Pricing</li>
              <li>✓ Locally Owned & Operated</li>
            </ul>
          </div>

          <div class="sidebar-card dark">
            <h3>Need Emergency Service?</h3>
            <p>
              Storm damage or a hazardous tree can't wait. Call our emergency
              line now for priority dispatch.
            </p>
            <a href={`tel:${site.phoneTel}`} class="sidebar-cta-btn">{site.phone}</a>
          </div>

          <div class="sidebar-card">
            <h3>Areas We Serve</h3>
            <div class="area-pills">
              {site.locations.map((loc) => (
                <a href={`/${loc.slug}/`} class="pill">{loc.name}</a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ── Hero ────────────────────────────────────────── */
  .contact-hero {
    background: linear-gradient(135deg, var(--green-900), var(--green-800));
    background-image: url('/images/hero-contact.svg');
    background-size: cover;
    background-position: center;
    color: #fff;
    text-align: center;
    padding: 4.5rem 1.5rem 3.5rem;
  }
  .contact-hero .section-label {
    color: var(--green-400);
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .contact-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }
  .hero-sub {
    max-width: 560px;
    margin: 0 auto;
    opacity: 0.85;
    line-height: 1.6;
  }

  /* ── Quick Contact ──────────────────────────────── */
  .quick-contact {
    padding: 0;
    margin-top: -2rem;
    position: relative;
    z-index: 2;
  }
  .quick-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .quick-card {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  a.quick-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }
  .quick-icon {
    color: var(--green-600);
  }
  .quick-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--green-600);
  }
  .quick-value {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--green-900);
  }

  /* ── Main ────────────────────────────────────────── */
  .contact-main {
    padding: 4rem 1.5rem 5rem;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  /* ── Form ────────────────────────────────────────── */
  .form-wrap h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    color: var(--green-900);
    margin-bottom: 0.5rem;
  }
  .form-wrap > p {
    color: var(--gray-600);
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-row.two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .field label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.35rem;
    color: var(--green-800);
  }
  .req {
    color: #c0392b;
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border: 1.5px solid var(--green-200);
    border-radius: 8px;
    font-size: 1rem;
    font-family: var(--font-body);
    transition: border-color 0.2s, box-shadow 0.2s;
    background: #fff;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--green-500);
    box-shadow: 0 0 0 3px rgba(34, 120, 69, 0.12);
  }
  .field textarea {
    resize: vertical;
  }
  .hidden {
    display: none;
  }
  .contact-form .btn-primary {
    width: 100%;
    justify-content: center;
  }

  /* ── Sidebar ─────────────────────────────────────── */
  .sidebar-card {
    background: var(--green-50);
    border-radius: 12px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }
  .sidebar-card.dark {
    background: var(--green-800);
    color: #fff;
  }
  .sidebar-card h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }
  .sidebar-card.dark p {
    opacity: 0.9;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .check-list li {
    font-size: 0.95rem;
    color: var(--green-800);
  }
  .sidebar-cta-btn {
    display: inline-block;
    background: #fff;
    color: var(--green-800);
    font-weight: 700;
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 1.05rem;
    transition: background 0.2s;
  }
  .sidebar-cta-btn:hover {
    background: var(--green-100);
  }
  .area-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pill {
    background: var(--green-200);
    color: var(--green-800);
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s;
  }
  .pill:hover {
    background: var(--green-300);
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .quick-grid {
      grid-template-columns: 1fr;
    }
    .form-row.two-col {
      grid-template-columns: 1fr;
    }
  }
</style>
